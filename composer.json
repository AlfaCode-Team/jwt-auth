{
  "name": "alfacode-team/jwt-auth",
  "description": "Standalone, production-grade JWT authentication library for PHP 8.1+ — no framework required.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-openssl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "AlfaCode\\PhpJWT\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AlfaCode\\PhpJWT\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit tests/"
  },
  "keywords": ["jwt", "auth", "authentication", "token", "php", "standalone"],
  "minimum-stability": "stable"
}
